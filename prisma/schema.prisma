// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init
datasource db {
  provider = "postgresql"
  schemas = ["game"]
}

generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/game-client"
}

// region Game Models
enum ItemType {
  CONSUMABLE   // 소모품
  EQUIPMENT    // 장비
  MATERIAL     // 재료
  ETC          // 기타

  @@schema("game")
}

enum ItemGrade {
  COMMON
  RARE
  EPIC
  LEGENDARY

  @@schema("game")
}

enum EquipmentSlot {
  WEAPON
  ARMOR
  HELMET
  RING

  @@schema("game")
}

model Item {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  price       Int

  type        ItemType
  grade       ItemGrade

  slot        EquipmentSlot?   // 장비 전용
  stackable   Boolean     @default(true)
  maxStack    Int?

  sellable    Boolean     @default(true)

  iconUrl     String?

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  userItems   UserItem[]

  @@schema("game")
}

model UserProfile {
  id        Int      @id @default(autoincrement())
  accountId Int      @unique
  nickname  String   @unique
  createdAt DateTime @default(now())

  items     UserItem[]

  @@schema("game")
}

model UserItem{
  id         Int      @id @default(autoincrement())
  userId     Int
  itemId     Int
  quantity   Int      @default(1)

  user       UserProfile     @relation(fields: [userId], references: [accountId], onDelete: Cascade)
  item       Item            @relation(fields: [itemId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())
    
  @@index([userId])
  @@index([itemId])

  @@schema("game")
}